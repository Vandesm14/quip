(#def a 2)
(def 'a 2)

(#def now (get-time))
(print now) ;; -> (get-time)

(def 'now (get-time))
(print now) ;; -> <the current time>

(#defn add [a b] (print a) (print b) (+ 2 2))
(defn 'add '[a b] '(print a) '(print b) '(+ 2 2))
(def 'add (fn '[a b] '(print a) '(print b) '(+ 2 2)))

(#if (= a b) (print "true"))
(if '(= a b) '(print "true"))

["foo" "bar"]
(arr "foo" "bar")

{"foo" 1 "bar" 2}
(map "foo" 1 "bar" 2)
